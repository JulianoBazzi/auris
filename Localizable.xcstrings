    "Grant Screen Recording, then restart Auris to capture system audio. Recording continues with the microphone only.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Grant Screen Recording, then restart Auris to capture system audio. Recording continues with the microphone only."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Concede Grabación de Pantalla y reinicia Auris para capturar el audio del sistema. La grabación continúa solo con el micrófono."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Conceda Gravação de Tela e reinicie o Auris para capturar o áudio do sistema. A gravação continua só com o microfone."
          }
        }
      }
    },
    "Grant a few permissions so Auris can record, transcribe and summarize your meetings.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Grant a few permissions so Auris can record, transcribe and summarize your meetings."
