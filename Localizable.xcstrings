    "Auris is turning the transcript into an executive summary.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Auris is turning the transcript into an executive summary."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Auris está convirtiendo la transcripción en un resumen ejecutivo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Auris está transformando a transcrição em um resumo executivo."
          }
        }
      }
    },
    "Auris waits for the microphone and system audio, transcribes on-device, and turns the conversation into a clean summary.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Auris waits for the microphone and system audio, transcribes on-device, and turns the conversation into a clean summary."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Auris espera el micrófono y el audio del sistema, transcribe en el dispositivo y convierte la conversación en un resumen claro."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Auris aguarda o microfone e o áudio do sistema, transcreve no dispositivo e transforma a conversa em um resumo limpo."
          }
        }
      }
    },
