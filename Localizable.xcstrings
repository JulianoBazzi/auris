    "Recording laws vary by country and state. Make sure every participant is aware and agrees before you record.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Recording laws vary by country and state. Make sure every participant is aware and agrees before you record."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las leyes de grabación varían según el país y el estado. Asegúrate de que todos los participantes lo sepan y estén de acuerdo antes de grabar."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As leis de gravação variam por país e estado. Garanta que todos os participantes saibam e concordem antes de gravar."
